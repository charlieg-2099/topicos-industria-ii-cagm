        """


rule NPZ_to_H5_digihit:
    input:
        '../data/3_Analisis_NPZ/{v}/{p}/wcs_MCA_{p}__{c}_500_MeV.npz'
    output:
        '../data/6_HD5/{v}/{p}/wcs_MCA_{p}__{c}_500_MeV.h5'
    params:
        host_py=HOST_PY
    group: "mygroup"
    shell:
        """
        mkdir -p "$(dirname {output})"
        {params.host_py} ../scripts/python/np_to_digihit_array_hdf5_FJOL.py {input} -o {output}
        """